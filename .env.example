# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/restaurant_agent
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=restaurant_agent

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# POS System Integration
POS_API_URL=https://pos-system.example.com/api
POS_API_KEY=your_pos_api_key
POS_SECRET=your_pos_secret

# CRM System Integration
CRM_API_URL=https://crm-system.example.com/api
CRM_API_KEY=your_crm_api_key

# Third-party Services
SENTIMENT_API_URL=https://sentiment-api.example.com
SENTIMENT_API_KEY=your_sentiment_api_key

# Features
ENABLE_REAL_TIME_SYNC=true
ENABLE_PREDICTIONS=true
CACHE_ENABLED=true
CACHE_TTL=3600
