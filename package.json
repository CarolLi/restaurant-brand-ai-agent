{
  "name": "restaurant-brand-ai-agent",
  "version": "1.0.0",
  "description": "全链路餐饮品牌智能运营与决策系统 - 集成品牌营销、行业洞察与多维销售分析的AI Agent平台",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "langchain": "^0.1.0",
    "openai": "^4.0.0",
    "axios": "^1.6.0",
    "pg": "^8.10.0",
    "redis": "^4.6.0",
    "puppeteer": "^21.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  },
  "keywords": ["restaurant", "ai-agent", "restaurant-management", "sales-analytics"],
  "author": "CarolLi",
  "license": "MIT"
}
